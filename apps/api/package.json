    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.19.2"
  }
